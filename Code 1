# Plot 2: 2x3 ENSEMBLE TLS IDENTIFIABILITY GRID
fig, axes = plt.subplots(2, 3, figsize=(18, 10), sharex=True)
axes = axes.flatten()
t1_true_dist = 1.0 / l_history
x_grid = np.linspace(30, 75, 1000).reshape(-1, 1)

for i, n in enumerate(model_order):
    axes[i].hist(t1_true_dist, bins=40, density=True, color='gray', alpha=0.3, label=r"Actual $T_1$")

    # Extraction Test: Recovering the distribution across 2000 iterations
    m_p = np.mean(preds[n], axis=0)
    l_vals = effective_lambda(X, m_p)
    t1_ext = 1.0 / np.clip(l_vals, 1e-8, None)

    # Kernel Density estimation for the model's performance footprint
    kde = KernelDensity(bandwidth=1.2).fit(t1_ext.reshape(-1, 1))
    axes[i].plot(x_grid, np.exp(kde.score_samples(x_grid)), color='red', linewidth=2, label=f"{n} KDE")
    axes[i].set_title(f"TLS Identifiability: {n}")
    axes[i].set_xlabel(r"$T_1$ Lifetime ($\mu s$)")
    axes[i].legend()

plt.tight_layout(); plt.show()
# =========================================================
# 7. TLS BIMODALITY ANALYSIS (MC=30)
# =========================================================
print("\n=== TLS BIMODALITY ANALYSIS (MC=30) ===\n")

bic_rows = []

for n in model_order:

    delta_bics = []
    bic1_vals = []
    bic2_vals = []

    for p_curr in preds[n]:

        # Recover effective lambda
        l_vals = effective_lambda(X, p_curr)

        # Convert to extracted T1 distribution
        t1_ext = 1.0 / np.clip(l_vals, 1e-8, None)

        # Compute 1-mode vs 2-mode BIC
        bic1, bic2 = bimodality_bics(t1_ext)

        bic1_vals.append(bic1)
        bic2_vals.append(bic2)
        delta_bics.append(bic1 - bic2)

    bic1_vals = np.array(bic1_vals)
    bic2_vals = np.array(bic2_vals)
    delta_bics = np.array(delta_bics)

    bic_rows.append({
        "Model": n,
        "BIC_1": f"{bic1_vals.mean():.3f} ± {bic1_vals.std():.3f}",
        "BIC_2": f"{bic2_vals.mean():.3f} ± {bic2_vals.std():.3f}",
        "Delta_BIC": f"{delta_bics.mean():.3f} ± {delta_bics.std():.3f}"
    })

bic_df = pd.DataFrame(bic_rows)

print(bic_df.to_string(index=False))

print("\nInterpretation:")
print("Positive ΔBIC = bimodal (2-component) structure preferred")
print("Negative ΔBIC = unimodal (1-component) structure preferred")
